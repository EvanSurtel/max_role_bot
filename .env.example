# ═══════════════════════════════════════════════════════════
# Rank $ CODM Cash Match Bot — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values.

# ─── Discord (REQUIRED) ──────────────────────────────────
BOT_TOKEN=your_discord_bot_token
CLIENT_ID=your_discord_client_id
GUILD_ID=your_discord_guild_id

# Roles (all admin-equivalent for permissions + pings)
ADMIN_ROLE_ID=
OWNER_ROLE_ID=
CEO_ROLE_ID=
ADS_ROLE_ID=
WAGER_STAFF_ROLE_ID=
XP_STAFF_ROLE_ID=
MEMBER_ROLE_ID=

# Rank roles (assigned automatically based on XP — leave blank to skip)
BRONZE_ROLE_ID=
SILVER_ROLE_ID=
GOLD_ROLE_ID=
PLATINUM_ROLE_ID=
DIAMOND_ROLE_ID=
SENTINEL_ROLE_ID=
OBSIDIAN_ROLE_ID=
CROWNED_ROLE_ID=

# ─── Channel IDs (REQUIRED) ─────────────────────────────
WELCOME_CHANNEL_ID=
WAGER_CHANNEL_ID=
XP_MATCH_CHANNEL_ID=
WALLET_CHANNEL_ID=
ADMIN_WALLET_VIEWER_CHANNEL_ID=
CHALLENGES_CHANNEL_ID=
XP_CHALLENGES_CHANNEL_ID=
XP_LEADERBOARD_CHANNEL_ID=
EARNINGS_LEADERBOARD_CHANNEL_ID=
RESULTS_CHANNEL_ID=
WAGER_RESULTS_CHANNEL_ID=
ADMIN_ALERTS_CHANNEL_ID=
SEASON_CHANNEL_ID=
TRANSACTIONS_CHANNEL_ID=
DISPUTE_RESULTS_CHANNEL_ID=
RULES_CHANNEL_ID=
HOW_IT_WORKS_CHANNEL_ID=
RANKS_CHANNEL_ID=

# ─── Base Chain (REQUIRED) ───────────────────────────────
# "sepolia" for testing, "mainnet" for production
BASE_NETWORK=sepolia
# Leave blank for public RPC, or paste an Alchemy/QuickNode URL
BASE_RPC_URL=
# Leave blank on mainnet (auto-uses native USDC). For testnet set your test token address.
USDC_CONTRACT_ADDRESS=

# ─── CDP Credentials (REQUIRED) ──────────────────────────
# From https://portal.cdp.coinbase.com → API Keys (@coinbase/cdp-sdk)
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=
# Coinbase Onramp app ID (for Group A deposits)
CDP_API_KEY=
# Owner account address — signs createMatch/resolveMatch/cancelMatch on the escrow contract
CDP_OWNER_ADDRESS=

# ─── Changelly Fiat API (Group B deposits) ───────────────
# From https://fiat-api.changelly.com — sign up for API access
CHANGELLY_FIAT_API_KEY=
CHANGELLY_FIAT_API_SECRET=
CHANGELLY_FIAT_API_URL=https://fiat-api.changelly.com/v1
# Callback public key — verifies webhook signatures from Changelly
CHANGELLY_CALLBACK_PUBLIC_KEY=

# ─── Smart Contract (REQUIRED) ───────────────────────────
# Paste here after running: node scripts/deploy-escrow.js
ESCROW_CONTRACT_ADDRESS=

# ─── Security (REQUIRED) ─────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ─── Platform Settings ───────────────────────────────────
MIN_WAGER_USDC=0.50
MAX_WAGER_USDC=100
MATCH_INACTIVITY_HOURS=24

# ─── NeatQueue (XP sync) ─────────────────────────────────
NEATQUEUE_API_TOKEN=
NEATQUEUE_CHANNEL_ID=

# ─── Webhook Server ──────────────────────────────────────
# Port the webhook HTTP server listens on. Default 3001.
WEBHOOK_PORT=3001
# PUBLIC URL (scheme + host + port) Changelly can call back at.
# e.g. http://your-server-ip:3001 or https://your-domain.com
# Required for Changelly fiat deposits/offramp to work.
WEBHOOK_HOST=

# ─── Season ──────────────────────────────────────────────
# Optional — defaults to 2026-S1. Change per season.
CURRENT_SEASON=2026-S1
