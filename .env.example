# ═══════════════════════════════════════════════════════════
# Rank $ CODM Wager Bot — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values.
# Lines starting with # are comments.

# ─── Discord ──────────────────────────────────────────────
BOT_TOKEN=your_discord_bot_token
CLIENT_ID=your_discord_client_id
GUILD_ID=your_discord_guild_id

# Roles (all admin-equivalent for permissions + pings)
ADMIN_ROLE_ID=
OWNER_ROLE_ID=
CEO_ROLE_ID=
ADS_ROLE_ID=
WAGER_STAFF_ROLE_ID=
XP_STAFF_ROLE_ID=
MEMBER_ROLE_ID=

# Rank roles (assigned automatically based on XP)
BRONZE_ROLE_ID=
SILVER_ROLE_ID=
GOLD_ROLE_ID=
PLATINUM_ROLE_ID=
DIAMOND_ROLE_ID=
SENTINEL_ROLE_ID=
OBSIDIAN_ROLE_ID=
CROWNED_ROLE_ID=

# ─── Channel IDs ─────────────────────────────────────────
WELCOME_CHANNEL_ID=
WAGER_CHANNEL_ID=
XP_MATCH_CHANNEL_ID=
WALLET_CHANNEL_ID=
ADMIN_WALLET_VIEWER_CHANNEL_ID=
CHALLENGES_CHANNEL_ID=
XP_CHALLENGES_CHANNEL_ID=
WAGER_SETUP_CATEGORY_ID=
XP_SETUP_CATEGORY_ID=
XP_LEADERBOARD_CHANNEL_ID=
EARNINGS_LEADERBOARD_CHANNEL_ID=
RESULTS_CHANNEL_ID=
WAGER_RESULTS_CHANNEL_ID=
ADMIN_ALERTS_CHANNEL_ID=
SEASON_CHANNEL_ID=
TRANSACTIONS_CHANNEL_ID=
DISPUTE_RESULTS_CHANNEL_ID=
RULES_CHANNEL_ID=
HOW_IT_WORKS_CHANNEL_ID=
RANKS_CHANNEL_ID=

# ─── Base Chain ───────────────────────────────────────────
# Network: "mainnet" for production, "sepolia" for testing
BASE_NETWORK=sepolia

# RPC endpoint — public works for testing, use Alchemy/QuickNode for production
# Mainnet: https://mainnet.base.org (or Alchemy Base mainnet endpoint)
# Testnet: https://sepolia.base.org (or Alchemy Base Sepolia endpoint)
BASE_RPC_URL=

# USDC contract address
# Mainnet (leave blank — defaults to native Circle USDC): 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# Testnet: deploy your own test ERC-20 or use a Base Sepolia USDC faucet address
USDC_CONTRACT_ADDRESS=

# ─── Coinbase Developer Platform (CDP) ───────────────────
# Get these from https://portal.cdp.coinbase.com
# Used for: Smart Account creation, transaction signing, Paymaster
CDP_API_KEY_NAME=                  # organizations/xxx/apiKeys/yyy
CDP_API_KEY_SECRET=                # EC private key (PEM format, starts with -----BEGIN EC PRIVATE KEY-----)
CDP_PROJECT_ID=                    # your CDP project UUID

# Paymaster — sponsors gas for all user transactions
# Get from CDP portal → Onchain Tools → Paymaster → Base (Mainnet or Sepolia)
PAYMASTER_RPC_URL=

# Owner CDP wallet — the wallet that calls admin functions on the escrow contract
# (createMatch, resolveMatch, cancelMatch). Export with wallet.export() after creation.
CDP_OWNER_WALLET_DATA=

# ─── Smart Contract ───────────────────────────────────────
# Escrow contract address (set after deploying with: node scripts/deploy-escrow.js)
ESCROW_CONTRACT_ADDRESS=

# Deployer private key — only needed ONCE to deploy the escrow contract.
# NOT used at runtime. Any wallet with ETH on Base (mainnet or sepolia).
DEPLOYER_PRIVATE_KEY=

# ─── Security ─────────────────────────────────────────────
# 32-byte hex key for AES-256-GCM encryption of wallet data
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ─── Platform Settings ────────────────────────────────────
MIN_WAGER_USDC=0.50
MAX_WAGER_USDC=100
MIN_WITHDRAWAL_USDC=5
MATCH_INACTIVITY_HOURS=24
CURRENT_SEASON=2026-S1

# ─── NeatQueue (XP sync) ─────────────────────────────────
NEATQUEUE_API_TOKEN=
NEATQUEUE_CHANNEL_ID=

# ─── Webhook Server ──────────────────────────────────────
# For future integrations (Alchemy deposit webhooks, etc.)
WEBHOOK_PORT=3001
