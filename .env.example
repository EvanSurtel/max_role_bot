# ═══════════════════════════════════════════════════════════
# Rank $ CODM Cash Match Bot — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values.

# ─── Discord (REQUIRED) ──────────────────────────────────
BOT_TOKEN=your_discord_bot_token
CLIENT_ID=your_discord_client_id
GUILD_ID=your_discord_guild_id

# Roles (all admin-equivalent for permissions + pings)
ADMIN_ROLE_ID=
OWNER_ROLE_ID=
CEO_ROLE_ID=
ADS_ROLE_ID=
WAGER_STAFF_ROLE_ID=
XP_STAFF_ROLE_ID=
MEMBER_ROLE_ID=

# Rank roles (assigned automatically based on XP — leave blank to skip)
BRONZE_ROLE_ID=
SILVER_ROLE_ID=
GOLD_ROLE_ID=
PLATINUM_ROLE_ID=
DIAMOND_ROLE_ID=
SENTINEL_ROLE_ID=
OBSIDIAN_ROLE_ID=
CROWNED_ROLE_ID=

# ─── Channel IDs (REQUIRED) ─────────────────────────────
WELCOME_CHANNEL_ID=
WAGER_CHANNEL_ID=
XP_MATCH_CHANNEL_ID=
WALLET_CHANNEL_ID=
ADMIN_WALLET_VIEWER_CHANNEL_ID=
CHALLENGES_CHANNEL_ID=
XP_CHALLENGES_CHANNEL_ID=
XP_LEADERBOARD_CHANNEL_ID=
EARNINGS_LEADERBOARD_CHANNEL_ID=
RESULTS_CHANNEL_ID=
WAGER_RESULTS_CHANNEL_ID=
ADMIN_ALERTS_CHANNEL_ID=
SEASON_CHANNEL_ID=
TRANSACTIONS_CHANNEL_ID=
# XP/Queue event feed (queue matches, XP awards, no-shows, subs, DQs). Separate from cash transactions.
XP_TRANSACTIONS_CHANNEL_ID=
DISPUTE_RESULTS_CHANNEL_ID=
# Support ticket system (see docs/SOP.md §user support runbooks)
# Where the support panel + category dropdown live (visible to all members)
SUPPORT_CHANNEL_ID=
# Discord category under which new ticket channels are created (kept tidy)
TICKETS_CATEGORY_ID=
# Staff-only log channel where transcripts post on close
TICKET_LOGS_CHANNEL_ID=
RULES_CHANNEL_ID=
HOW_IT_WORKS_CHANNEL_ID=
RANKS_CHANNEL_ID=
# XP / Match Stats leaderboard (all match types: queue, XP challenge, cash match)
QUEUE_STATS_CHANNEL_ID=
# Cash Match Stats leaderboard (earnings, wagered, cash match W/L)
WAGER_STATS_CHANNEL_ID=
# 5v5 Ranked Queue — join/leave panel lives here
RANKED_QUEUE_CHANNEL_ID=

# ─── Base Chain (REQUIRED) ───────────────────────────────
# "sepolia" for testing, "mainnet" for production
BASE_NETWORK=sepolia
# Leave blank for public RPC, or paste an Alchemy/QuickNode URL
BASE_RPC_URL=
# Optional fallback RPC — enables FallbackProvider for automatic failover
BASE_RPC_URL_FALLBACK=
# Leave blank on mainnet (auto-uses native USDC). For testnet set your test token address.
USDC_CONTRACT_ADDRESS=

# ─── CDP Credentials (REQUIRED) ──────────────────────────
# From https://portal.cdp.coinbase.com → API Keys (@coinbase/cdp-sdk)
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=
# CDP Project ID — used as the Coinbase Onramp `appId` for Group A deposits.
# Find it at portal.cdp.coinbase.com → your project → Project ID.
CDP_PROJECT_ID=

# CDP Paymaster RPC URL. OPTIONAL on Base mainnet — the CDP SDK
# auto-resolves the paymaster URL from your CDP_API_KEY_ID +
# CDP_API_KEY_SECRET when this is unset AND network === "base"
# (the SDK hits /apikeys/v1/tokens/active to get your project's
# default Base Node RPC URL, which doubles as the paymaster URL).
# REQUIRED on Base Sepolia — the SDK does not auto-resolve for testnet.
#
# Set this explicitly to override the auto-default (e.g. if you want
# a different paymaster than the project default).
#
# If you see "sender balance and deposit together is 0 but must be at
# least N to pay for this operation", the Paymaster isn't sponsoring.
# Check in this order:
#   1. CDP dashboard → Paymaster → your network → is it ENABLED?
#   2. Allowlist includes the contracts being called? You need:
#      - USDC contract (0x833589fCD6...) for approve() during onboarding
#      - Escrow contract (your ESCROW_CONTRACT_ADDRESS) for
#        createMatch / depositToEscrow / resolveMatch / cancelMatch
#   3. CDP_API_KEY_ID / CDP_API_KEY_SECRET valid + have Paymaster perms?
#      (the SDK silently returns undefined on auth failures)
#   4. Project's paymaster budget / per-user limit not exceeded?
#
# Format when set: https://api.developer.coinbase.com/rpc/v1/<network>/<key>
PAYMASTER_RPC_URL=

# Payment router feature flags. See src/services/paymentRouter.js.
# - CDP_ONRAMP_ENABLED: master toggle for showing Coinbase Onramp at all
# - CDP_OFFRAMP_ENABLED: keep false until Coinbase approves offramp
# - CDP_ZERO_FEE_USDC: flip true when zero-fee USDC approval lands (labels only)
# - CDP_TRIAL_MAX_TRANSACTIONS: trial-mode transaction count cap
#     (25 by default; bump when full access is approved)
# - CDP_TRIAL_MAX_AMOUNT_USD: per-transaction dollar cap during trial
#     ($5 by default; bump when full access is approved). If the user
#     requests a deposit > this amount, the router hides CDP entirely
#     (they can still use Wert / Transak for the larger amount).
# - CDP_WEBHOOK_SECRET: required on mainnet for /api/coinbase/webhook
CDP_ONRAMP_ENABLED=true
CDP_OFFRAMP_ENABLED=false
CDP_ZERO_FEE_USDC=false
CDP_TRIAL_MAX_TRANSACTIONS=25
CDP_TRIAL_MAX_AMOUNT_USD=5
CDP_WEBHOOK_SECRET=

# Bitrefill — affiliate link offramp (gift cards, no KYC). Sign up at
# bitrefill.com/affiliate. If unset, the Bitrefill button still works
# but without affiliate attribution.
BITREFILL_AFFILIATE_CODE=

# Owner account address — signs createMatch/resolveMatch/cancelMatch on the escrow contract
CDP_OWNER_ADDRESS=

# ─── Self-Custody Wallet Web Surface ──────────────────────
# The Next.js app at web/ (deployed on Vercel) where users sign
# their Smart Wallet creation, EIP-712 SpendPermissions, and
# external withdrawals via WebAuthn passkey. The bot DMs users
# one-time URLs into here whenever an action requires a real
# cryptographic user signature.
#
# WALLET_WEB_BASE_URL — public URL of the Vercel deploy. The bot
#   builds setup/withdraw/renew links from this. Use the
#   rank-wallet-<slug>.vercel.app URL until you wire a custom
#   domain. Trailing slash optional.
# WALLET_WEB_INTERNAL_SECRET — shared secret the web app sends in
#   X-Internal-Secret header on calls to /api/internal/*. Keep
#   this long + random (32+ bytes hex). Rotate if leaked.
WALLET_WEB_BASE_URL=
WALLET_WEB_INTERNAL_SECRET=

# ─── Changelly Fiat API (Group B deposits) ───────────────
# From https://fiat-api.changelly.com — sign up for API access
CHANGELLY_FIAT_API_KEY=
CHANGELLY_FIAT_API_SECRET=
CHANGELLY_FIAT_API_URL=https://fiat-api.changelly.com/v1
# Callback public key — verifies webhook signatures from Changelly
CHANGELLY_CALLBACK_PUBLIC_KEY=

# ─── Smart Contract (REQUIRED) ───────────────────────────
# Paste here after running: node scripts/deploy-escrow.js
ESCROW_CONTRACT_ADDRESS=

# ─── Platform Settings ───────────────────────────────────
MIN_WAGER_USDC=0.50
MAX_WAGER_USDC=100
MATCH_INACTIVITY_HOURS=24

# ─── Webhook Server ──────────────────────────────────────
# Port the webhook HTTP server listens on. Default 3001.
WEBHOOK_PORT=3001
# PUBLIC URL (scheme + host + port) Changelly can call back at.
# e.g. http://your-server-ip:3001 or https://your-domain.com
# Required for Changelly fiat deposits/offramp to work.
WEBHOOK_HOST=

# ─── Season ──────────────────────────────────────────────
# Optional — defaults to 2026-S1. Change per season.
CURRENT_SEASON=2026-S1
