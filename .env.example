# Discord
BOT_TOKEN=your_discord_bot_token
CLIENT_ID=your_discord_client_id
GUILD_ID=your_discord_guild_id
ADMIN_ROLE_ID=your_admin_role_id
OWNER_ROLE_ID=your_owner_role_id
CEO_ROLE_ID=your_ceo_role_id
ADS_ROLE_ID=your_ads_role_id
WAGER_STAFF_ROLE_ID=your_wager_staff_role_id

# Rank roles — assigned automatically based on season XP (or top 10
# leaderboard position for Crowned). Each is optional: leave blank
# and that rank just won't be auto-assigned.
BRONZE_ROLE_ID=
SILVER_ROLE_ID=
GOLD_ROLE_ID=
PLATINUM_ROLE_ID=
DIAMOND_ROLE_ID=
SENTINEL_ROLE_ID=
OBSIDIAN_ROLE_ID=
CROWNED_ROLE_ID=
XP_STAFF_ROLE_ID=your_xp_staff_role_id
MEMBER_ROLE_ID=your_member_role_id

# Channel IDs
WELCOME_CHANNEL_ID=your_welcome_channel_id
WAGER_CHANNEL_ID=your_wager_lobby_channel_id
XP_MATCH_CHANNEL_ID=your_xp_match_channel_id
WALLET_CHANNEL_ID=your_public_wallet_channel_id
ADMIN_WALLET_VIEWER_CHANNEL_ID=your_admin_only_wallet_viewer_channel_id
WALLET_CATEGORY_ID=your_wallets_category_id  # legacy: old per-user wallet channels, can be removed after migration
CHALLENGES_CHANNEL_ID=your_wager_challenges_channel_id
XP_CHALLENGES_CHANNEL_ID=your_xp_challenges_channel_id
WAGER_SETUP_CATEGORY_ID=
XP_SETUP_CATEGORY_ID=
XP_LEADERBOARD_CHANNEL_ID=your_xp_leaderboard_channel_id
EARNINGS_LEADERBOARD_CHANNEL_ID=your_earnings_leaderboard_channel_id
RESULTS_CHANNEL_ID=your_all_results_channel_id
WAGER_RESULTS_CHANNEL_ID=your_wager_only_results_channel_id
ADMIN_ALERTS_CHANNEL_ID=your_admin_alerts_channel_id
SEASON_CHANNEL_ID=your_season_management_channel_id
ESCROW_CHANNEL_ID=  # legacy: escrow panel now lives in ADMIN_WALLET_VIEWER_CHANNEL_ID; set this only as fallback
TRANSACTIONS_CHANNEL_ID=your_admin_transactions_channel_id
DISPUTE_RESULTS_CHANNEL_ID=your_dispute_results_channel_id
RULES_CHANNEL_ID=your_rules_channel_id
HOW_IT_WORKS_CHANNEL_ID=your_how_it_works_channel_id
RANKS_CHANNEL_ID=your_ranks_channel_id

# Solana
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=
ESCROW_WALLET_SECRET=[your,escrow,wallet,secret,key,as,json,array]
USDC_MINT_ADDRESS=

# Security
ENCRYPTION_KEY=your_64_char_hex_string_for_aes256gcm

# Platform
MIN_WAGER_USDC=0.50
MAX_WAGER_USDC=100
MIN_WITHDRAWAL_USDC=0.50
MIN_SOL_FOR_GAS=0.005
ESCROW_SOL_WARNING_THRESHOLD=0.05
ESCROW_SOL_CRITICAL_THRESHOLD=0.01

# Match
MATCH_INACTIVITY_HOURS=24

# Season
CURRENT_SEASON=2026-S1

# NeatQueue
NEATQUEUE_API_TOKEN=
NEATQUEUE_CHANNEL_ID=
