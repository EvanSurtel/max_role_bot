# Rank $ wallet web surface — environment.
# Copy to .env.local for local dev. On Vercel, set these in
# Project Settings → Environment Variables.

# ─── Bot backend (REQUIRED) ───────────────────────────────────────
# The Discord bot exposes a small HTTP API for the web surface to
# call (record signed SpendPermissions, validate one-time link
# nonces, etc). All requests are authed with a shared secret.
BOT_API_BASE_URL=https://your-bot-host.example.com
BOT_API_SHARED_SECRET=

# ─── Coinbase Smart Wallet / OnchainKit (REQUIRED) ────────────────
# CDP project ID — used by OnchainKit to identify which Smart Wallet
# project requests come from. Same value as the bot's CDP_PROJECT_ID.
NEXT_PUBLIC_CDP_PROJECT_ID=

# Base RPC. Public endpoint is fine for read-only client work; for
# production you may want an Alchemy/QuickNode URL to avoid rate
# limits on user-initiated reads.
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org

# Backend spender address — the address users will grant the
# SpendPermission to. Must match the bot's escrow-owner-smart
# Smart Account (currently 0x407AA75dC2f0D3B7A50dceCbC4BC061Ff92542e6
# on mainnet). The web app pre-fills this in the SpendPermission
# struct so the user signs the right value.
NEXT_PUBLIC_BOT_SPENDER_ADDRESS=

# ─── Discord OAuth (REQUIRED) ─────────────────────────────────────
# Bot's Discord application credentials. Used to verify the user's
# Discord identity before binding it to a Smart Wallet address.
# Create at https://discord.com/developers/applications → your app →
# OAuth2. Add the redirect URI <NEXT_PUBLIC_APP_URL>/api/discord/callback
# to the application's redirect list.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
NEXT_PUBLIC_APP_URL=https://rank-wallet.vercel.app
